            function generateDiagram() {
                if (!currentRecommendation) {
                    alert("Please select a valid recommendation first.");
                    return;
                }

                const pattern = currentRecommendation['Recommended Architecture Pattern'];
                if (!pattern) {
                    alert("The current recommendation does not have a defined architecture pattern to diagram.");
                    return;
                }

                // Show the diagram section
                diagramSection.style.display = 'block';
                diagramContainer.innerHTML = 'Generating diagram...';

                console.log("Generating diagram for pattern:", pattern);

                const xml = generateDiagramXmlForPattern(pattern);
                if (xml) {
                    diagramContainer.innerHTML = '';
                    const graph = new Graph(diagramContainer);
                    graph.setEnabled(false);
                    graph.setConnectable(false);
                    graph.setPanning(true);
                    const xmlDoc = mxUtils.parseXml(xml);
                    const codec = new mxCodec(xmlDoc);
                    codec.decode(xmlDoc.documentElement, graph.getModel());
                    graph.fit();
                    graph.center(true, true);
                } else {
                    diagramContainer.innerHTML = 'Could not generate a diagram for this architecture pattern.';
                }
            }

