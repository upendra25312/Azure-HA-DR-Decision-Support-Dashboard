<!DOCTYPE html>
<html lang="en">
<head>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Azure HA/DR Decision Support Dashboard</title>
    <style>
                :root {
                    --bg: linear-gradient(180deg, #edf4fb 0%, #f8fbfd 48%, #ffffff 100%);
                    --panel-bg: rgba(255, 255, 255, 0.92);
                    --panel-border: #d6e2ee;
                    --text: #16324f;
                    --muted: #5d7288;
                    --accent: #0f6cbd;
                    --accent-dark: #0b4f8a;
                    --soft-accent: #e9f3fb;
                    --warning-bg: #fff8e8;
                    --warning-border: #e6c77a;
                    --warning-text: #7a5800;
                    --risk-bg: #fff1f1;
                    --risk-border: #efb3b3;
                    --risk-text: #8f2727;
                    --shadow: 0 18px 40px rgba(15, 46, 78, 0.08);
                }
                .help-icon {
                    display: inline-block;
                    margin-left: 6px;
                    color: var(--accent);
                    cursor: pointer;
                    font-size: 1em;
                    vertical-align: middle;
                }
                .help-tooltip {
                    display: none;
                    position: absolute;
                    background: #17324f;
                    color: #fff;
                    padding: 8px 12px;
                    border-radius: 6px;
                    font-size: 0.95em;
                    z-index: 2000;
                    max-width: 320px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.18);
                }
                .help-icon:hover + .help-tooltip, .help-icon:focus + .help-tooltip {
                    display: block;
                }
                .azure-link {
                    color: var(--accent);
                    text-decoration: underline;
                    font-size: 0.95em;
                    margin-left: 4px;
                }
                .error-banner {
                    background: #fee2e2;
                    color: #991b1b;
                    border: 1px solid #fca5a5;
                    padding: 10px 18px;
                    border-radius: 6px;
                    margin-bottom: 18px;
                    font-weight: bold;
                    display: none;
                }
        body {
            font-family: "Segoe UI", Aptos, "Helvetica Neue", sans-serif;
            margin: 0;
            padding: 2.25em;
            background: var(--bg);
            color: var(--text);
            transition: background 0.3s, color 0.3s;
        }
        h1 {
            color: var(--accent-dark);
            text-align: left;
            margin: 0 0 0.2em;
            font-size: 2.35rem;
            letter-spacing: -0.03em;
        }
        .page-header {
            max-width: 1400px;
            margin: 0 auto 1.5em;
        }
        .page-eyebrow {
            margin: 0 0 0.4em;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.12em;
            font-size: 0.8rem;
            font-weight: 700;
        }
        .page-subtitle {
            max-width: 980px;
            margin: 0;
            color: var(--muted);
            line-height: 1.55;
            font-size: 1rem;
        }
        .advisory-banner {
            margin: 1.25em 0 0;
            padding: 1em 1.15em;
            border-radius: 14px;
            border: 1px solid var(--warning-border);
            background: var(--warning-bg);
            color: var(--warning-text);
            line-height: 1.45;
            box-shadow: var(--shadow);
        }
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2em;
            max-width: 1400px;
            margin: 0 auto;
        }
        .input-section, .output-section {
            border: 1px solid var(--panel-border);
            padding: 1.2em;
            border-radius: 18px;
            background: var(--panel-bg);
            box-shadow: var(--shadow);
            backdrop-filter: blur(12px);
            transition: background 0.3s, color 0.3s;
        }
        h2 {
            margin-top: 0;
            color: var(--accent-dark);
            letter-spacing: -0.02em;
        }
        #diagram-section {
            grid-column: 1 / -1;
        }
        label {
            display: block;
            margin-bottom: 0.5em;
            font-weight: bold;
        }
        select, input {
            width: 100%;
            padding: 10px 12px;
            margin-bottom: 1em;
            border-radius: 10px;
            border: 1px solid #c4d3e0;
            background: #fff;
            color: var(--text);
            box-sizing: border-box;
        }
        .section-intro {
            margin: 0 0 1em;
            color: var(--muted);
            line-height: 1.5;
        }
        .catalog-context {
            margin: 0 0 1.2em;
            padding: 1em 1.05em;
            border: 1px solid #d6e7f5;
            border-radius: 14px;
            background: linear-gradient(180deg, #f7fbff 0%, #eef5fb 100%);
        }
        .catalog-context-title {
            margin: 0 0 0.45em;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--accent-dark);
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .context-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5em;
            margin-bottom: 0.7em;
        }
        .context-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.35em 0.7em;
            border-radius: 999px;
            background: #d9ebfb;
            color: #0d4f88;
            font-size: 0.84rem;
            font-weight: 700;
        }
        .context-copy {
            margin: 0;
            color: var(--muted);
            font-size: 0.93rem;
            line-height: 1.45;
        }
        .trust-strip {
            margin-bottom: 1em;
            padding: 1em 1.05em;
            border-radius: 14px;
            border: 1px solid #dbe7f3;
            background: linear-gradient(180deg, #fbfdff 0%, #f3f8fc 100%);
        }
        .trust-strip h3 {
            margin: 0 0 0.55em;
            font-size: 0.95rem;
            color: var(--accent-dark);
        }
        .trust-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8em;
        }
        .trust-item {
            padding: 0.8em;
            border-radius: 12px;
            background: #fff;
            border: 1px solid #e0e9f2;
        }
        .trust-label {
            display: block;
            margin-bottom: 0.35em;
            color: var(--muted);
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .trust-value {
            font-weight: 700;
            color: var(--text);
            line-height: 1.35;
        }
        .output-field {
            margin-bottom: 1em;
        }
        .output-field label {
            color: var(--text);
        }
        .output-field p {
            background-color: #f5f9fc;
            padding: 12px;
            border-radius: 10px;
            min-height: 20px;
            line-height: 1.5;
            border: 1px solid #e1ebf3;
        }
        .scorecard-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.75em;
            margin-bottom: 1.25em;
        }
        .scorecard {
            padding: 0.9em;
            border-radius: 12px;
            border: 1px solid #dbe4f0;
            background: linear-gradient(180deg, #f8fbff 0%, #eef5fb 100%);
        }
        .scorecard-label {
            display: block;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #5b6b7a;
            margin-bottom: 0.45em;
        }
        .scorecard-value {
            display: inline-block;
            padding: 0.35em 0.65em;
            border-radius: 999px;
            font-size: 0.95rem;
            font-weight: bold;
            background: #e2e8f0;
            color: #1f2937;
        }
        .scorecard-note {
            margin-top: 0.65em;
            color: #475569;
            font-size: 0.88rem;
            line-height: 1.35;
        }
        .score-low { background: #dcfce7; color: #166534; }
        .score-medium { background: #fef3c7; color: #92400e; }
        .score-high { background: #fee2e2; color: #991b1b; }
        .score-mixed { background: #dbeafe; color: #1d4ed8; }
        .score-strong { background: #dbeafe; color: #1e40af; }
        .score-partial { background: #ede9fe; color: #6d28d9; }
        .score-unknown { background: #e2e8f0; color: #475569; }
        .guardrail-panel {
            margin-bottom: 1em;
            padding: 1em 1.05em;
            border-radius: 14px;
            border: 1px solid var(--risk-border);
            background: var(--risk-bg);
        }
        .guardrail-panel h3 {
            margin: 0 0 0.45em;
            color: var(--risk-text);
            font-size: 0.95rem;
        }
        .guardrail-panel p {
            margin: 0;
            color: #7b3131;
            line-height: 1.45;
        }
        #theme-toggle {
            position: fixed;
            top: 20px;
            right: 30px;
            z-index: 1000;
            padding: 8px 16px;
            border-radius: 20px;
            border: none;
            background: #222;
            color: #fff;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s, color 0.3s;
        }
        body.dark-theme {
            background: #0d1117;
            color: #c9d1d9;
        }
        .dark-theme .input-section, .dark-theme .output-section {
            background: #161b22;
            color: #c9d1d9;
            border-color: #30363d;
            box-shadow: 0 8px 24px rgba(0,0,0,0.25);
        }
        .dark-theme .scorecard {
            background: linear-gradient(180deg, #161b22 0%, #0d1117 100%);
            border-color: #30363d;
        }
        .dark-theme .scorecard-label {
            color: #8b949e;
        }
        .dark-theme .scorecard-value {
            background: #21262d;
            color: #f0f6fc;
        }
        .dark-theme .scorecard-note {
            color: #8b949e;
        }
        .dark-theme .advisory-banner,
        .dark-theme .catalog-context,
        .dark-theme .trust-strip,
        .dark-theme .trust-item,
        .dark-theme .guardrail-panel,
        .dark-theme .output-field p {
            border-color: #30363d;
            background: #161b22;
        }
        .dark-theme .page-subtitle,
        .dark-theme .section-intro,
        .dark-theme .context-copy,
        .dark-theme .trust-label,
        .dark-theme .guardrail-panel p {
            color: #8b949e;
        }
        .dark-theme .catalog-context-title,
        .dark-theme .trust-strip h3,
        .dark-theme .guardrail-panel h3,
        .dark-theme .trust-value {
            color: #f0f6fc;
        }
        .dark-theme .context-badge {
            background: #1f2937;
            color: #bfdbfe;
        }
        .dark-theme h1, .dark-theme h2, .dark-theme h3, .dark-theme h4, .dark-theme h5, .dark-theme h6 {
            color: #f0f6fc;
        }
        .dark-theme label {
            color: #8b949e;
        }
        .dark-theme select, .dark-theme input {
            background: #0d1117;
            color: #c9d1d9;
            border-color: #30363d;
        }
        .dark-theme .output-field p {
            background-color: #161b22;
            color: #c9d1d9;
        }
        .dark-theme a, .dark-theme .link {
            color: #58a6ff;
        }
        .dark-theme #theme-toggle {
            background: #fff;
            color: #222;
        }
        /* Extra: make "Not rated" badges readable */
        .dark-theme .scorecard-value, .dark-theme .badge, .dark-theme .not-rated {
            color: #f0f6fc !important;
            background: #30363d !important;
        }
        @media (max-width: 960px) {
            body {
                padding: 1em;
            }
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
            .scorecard-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
            .trust-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <button id="theme-toggle" title="Toggle dark/light mode">🌙 Dark</button>
    <div class="page-header">
        <p class="page-eyebrow">Enterprise Advisory Tool</p>
        <h1>Azure HA/DR Decision Support Dashboard</h1>
        <p class="page-subtitle">Use this dashboard to compare high availability and disaster recovery approaches across Azure services, SaaS platforms, and dependency contexts. Recommendations are advisory, service-aware, and should be validated against workload-specific architecture, region support, and operational constraints before sign-off.</p>
        <div class="advisory-banner">This experience preserves the current live catalog, including legacy and dependency-oriented options. When recommendation coverage is partial or indirect, the dashboard now shows that explicitly instead of overstating confidence.</div>
    </div>
    <div id="error-banner" class="error-banner"></div>
    <div class="dashboard-grid">
        <div class="input-section">
            <h2>Decision Inputs</h2>
            <p class="section-intro">Select the primary service or platform context, then shape the recommendation using business recovery targets, topology preferences, and delivery trade-offs. The catalog remains broad by design; some options are service entries, while others represent dependency or legacy contexts that need additional human review.</p>
            <label for="azure-service">Select Azure Service
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">Choose the Azure service you want to architect for HA/DR. <a class="azure-link" href="https://learn.microsoft.com/azure/" target="_blank">Azure Docs</a></span>
            </label>
            <select id="azure-service">
                <option value="">--Please choose an option--</option>
                <option value=" Security"> Security</option><option value="API Management">API Management</option><option value="Azure AI Foundry related dependencies">Azure AI Foundry related dependencies</option><option value="Azure AI Search">Azure AI Search</option><option value="Azure AI Services">Azure AI Services</option><option value="Azure App Service">Azure App Service</option><option value="Azure Cache for Redis">Azure Cache for Redis</option><option value="Azure Container Apps">Azure Container Apps</option><option value="Azure Cosmos DB">Azure Cosmos DB</option><option value="Azure Data Lake Storage">Azure Data Lake Storage</option><option value="Azure Database for MySQL Flexible Server">Azure Database for MySQL Flexible Server</option><option value="Azure Database for PostgreSQL Flexible Server">Azure Database for PostgreSQL Flexible Server</option><option value="Azure Files">Azure Files</option><option value="Azure Functions">Azure Functions</option><option value="Azure Kubernetes Service (AKS)">Azure Kubernetes Service (AKS)</option><option value="Azure NetApp Files">Azure NetApp Files</option><option value="Azure OpenAI">Azure OpenAI</option><option value="Azure SQL Database">Azure SQL Database</option><option value="Azure SQL Managed Instance">Azure SQL Managed Instance</option><option value="Azure Service Bus">Azure Service Bus</option><option value="Azure Site-to-Site VPN">Azure Site-to-Site VPN</option><option value="Azure Storage Account">Azure Storage Account</option><option value="Azure VPN Gateway">Azure VPN Gateway</option><option value="Azure Virtual Machines">Azure Virtual Machines</option><option value="Azure Virtual WAN">Azure Virtual WAN</option><option value="Dynamics 365 (D365)">Dynamics 365 (D365)</option><option value="Event Grid">Event Grid</option><option value="Event Hubs">Event Hubs</option><option value="Integration Account">Integration Account</option><option value="Logic Apps">Logic Apps</option><option value="Microsoft Fabric">Microsoft Fabric</option><option value="SQL Server on Azure VMs">SQL Server on Azure VMs</option><option value="Virtual Machine Scale Sets">Virtual Machine Scale Sets</option>
            </select>

            <label for="workload-category">Select Workload Category
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">Pick the type of workload (e.g., Database, Compute, AI) to tailor recommendations. <a class="azure-link" href="https://learn.microsoft.com/azure/architecture/example-scenario/workloads/" target="_blank">Azure Workload Docs</a></span>
            </label>
            <select id="workload-category">
                <option value="">--Please choose an option--</option>
            </select>

            <label for="criticality">Select Criticality
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">How important is this workload? Critical workloads require the highest resiliency. <a class="azure-link" href="https://learn.microsoft.com/azure/architecture/framework/resiliency/overview" target="_blank">Resiliency Guidance</a></span>
            </label>
            <select id="criticality">
                <option value="">--Please choose an option--</option>
                <option value="Critical">Critical</option><option value="Important">Important</option><option value="PaaS">PaaS</option><option value="Standard">Standard</option>
            </select>

            <label for="rto">Desired RTO
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">Recovery Time Objective: Maximum acceptable downtime after a failure. <a class="azure-link" href="https://learn.microsoft.com/azure/architecture/resiliency/recovery-time-objective" target="_blank">RTO Docs</a></span>
            </label>
            <select id="rto">
                <option value="">--Please choose an option--</option>
                <option value="< 15 mins">&lt; 15 mins</option>
                <option value="15-60 mins">15-60 mins</option>
                <option value="1-4 hours">1-4 hours</option>
                <option value="4-12 hours">4-12 hours</option>
                <option value="12-24 hours">12-24 hours</option>
                <option value="> 24 hours">&gt; 24 hours</option>
            </select>

            <label for="rpo">Desired RPO
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">Recovery Point Objective: Maximum acceptable data loss (in time) after a failure. <a class="azure-link" href="https://learn.microsoft.com/azure/architecture/resiliency/recovery-point-objective" target="_blank">RPO Docs</a></span>
            </label>
            <select id="rpo">
                <option value="">--Please choose an option--</option>
                <option value="< 15 mins">&lt; 15 mins</option>
                <option value="15-60 mins">15-60 mins</option>
                <option value="1-4 hours">1-4 hours</option>
                <option value="4-12 hours">4-12 hours</option>
                <option value="12-24 hours">12-24 hours</option>
                <option value="> 24 hours">&gt; 24 hours</option>
            </select>

            <label for="region-preference">Region / Zone Preference
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">Choose your preferred Azure region or zone for deployment. <a class="azure-link" href="https://learn.microsoft.com/azure/availability-zones/az-overview" target="_blank">Availability Zones</a></span>
            </label>
            <select id="region-preference">
                <option value="">--Please choose an option--</option>
                <option value="Single Region">Single Region</option>
                <option value="Single Region, Multiple Zones">Single Region, Multiple Zones</option>
                <option value="Multiple Regions">Multiple Regions</option>
            </select>

            <label for="topology-preference">Topology Preference
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">Select the desired architecture topology (e.g., Active/Active, Active/Passive). <a class="azure-link" href="https://learn.microsoft.com/azure/architecture/patterns/category/resiliency" target="_blank">Resiliency Patterns</a></span>
            </label>
            <select id="topology-preference">
                <option value="">--Please choose an option--</option>
                <option value="Active-Active">Active-Active</option>
                <option value="Active-Passive (Hot Standby)">Active-Passive (Hot Standby)</option>
                <option value="Active-Passive (Cold Standby)">Active-Passive (Cold Standby)</option>
            </select>

            <label for="cost-sensitivity">Cost Sensitivity
                <span class="help-icon" tabindex="0"><i class="fa fa-circle-question"></i></span>
                <span class="help-tooltip">How sensitive is your workload to cost? <a class="azure-link" href="https://learn.microsoft.com/azure/architecture/framework/cost/overview" target="_blank">Cost Optimization</a></span>
            </label>
            <select id="cost-sensitivity">
                <option value="">--Please choose an option--</option>
                <option value="Low">Low</option>
                <option value="Medium">Medium</option>
                <option value="High">High</option>
            </select>

            <label for="simplicity-resilience">Simplicity vs Resilience</label>
            <select id="simplicity-resilience">
                <option value="">--Please choose an option--</option>
                <option value="Simplicity">Prioritize Simplicity</option>
                <option value="Balanced">Balanced</option>
                <option value="Resilience">Prioritize Resilience</option>
            </select>
            <div class="catalog-context">
                <div class="catalog-context-title">Selected Catalog Context</div>
                <div class="context-badges">
                    <span class="context-badge" id="catalog-item-type">Catalog type pending</span>
                    <span class="context-badge" id="catalog-service-category">Service category pending</span>
                    <span class="context-badge" id="catalog-coverage-status">Coverage pending</span>
                </div>
                <p class="context-copy" id="catalog-context-notes">Pick a service or platform context to see how the dashboard classifies it and how much direct recommendation coverage is available.</p>
            </div>
        </div>
        <div class="output-section">
            <h2>Recommendations</h2>
            <div class="trust-strip">
                <h3>Recommendation Basis</h3>
                <div class="trust-grid">
                    <div class="trust-item">
                        <span class="trust-label">Decision posture</span>
                        <div class="trust-value" id="decision-posture">Awaiting selection</div>
                    </div>
                    <div class="trust-item">
                        <span class="trust-label">Evidence basis</span>
                        <div class="trust-value" id="recommendation-basis">Select inputs to evaluate direct matrix coverage and fallback behavior.</div>
                    </div>
                    <div class="trust-item">
                        <span class="trust-label">Validation requirement</span>
                        <div class="trust-value" id="validation-requirement">Human review remains required for final architecture approval.</div>
                    </div>
                </div>
            </div>
            <div class="scorecard-grid" id="scorecard-grid">
                <div class="scorecard">
                    <span class="scorecard-label">Cost</span>
                    <span class="scorecard-value" id="scorecard-cost">Not rated</span>
                    <div class="scorecard-note" id="scorecard-cost-note">Spend profile based on the current recommendation.</div>
                </div>
                <div class="scorecard">
                    <span class="scorecard-label">Complexity</span>
                    <span class="scorecard-value" id="scorecard-complexity">Not rated</span>
                    <div class="scorecard-note" id="scorecard-complexity-note">Operational burden and implementation effort.</div>
                </div>
                <div class="scorecard">
                    <span class="scorecard-label">Resiliency</span>
                    <span class="scorecard-value" id="scorecard-resiliency">Not rated</span>
                    <div class="scorecard-note" id="scorecard-resiliency-note">Coverage across local, zonal, and regional failure modes.</div>
                </div>
                <div class="scorecard">
                    <span class="scorecard-label">Confidence</span>
                    <span class="scorecard-value" id="scorecard-confidence">Not rated</span>
                    <div class="scorecard-note" id="scorecard-confidence-note">Confidence combines source maturity with match quality and fallback distance.</div>
                </div>
            </div>
            <div class="guardrail-panel">
                <h3>Validation Guardrails</h3>
                <p id="validation-guardrails">Guardrails will appear here when a recommendation needs service-specific verification, region validation, or dependency review.</p>
            </div>
            <div id="recommendations-content">
                <div class="output-field">
                    <label>Recommended HA Approach</label>
                    <p id="ha-approach"></p>
                </div>
                <div class="output-field">
                    <label>Recommended DR Approach</label>
                    <p id="dr-approach"></p>
                </div>
                <div class="output-field">
                    <label>Recommended Architecture Pattern</label>
                    <p id="architecture-pattern"></p>
                </div>
                <div class="output-field">
                    <label>Resiliency Classification</label>
                    <p id="resiliency-classification"></p>
                </div>
                <div class="output-field">
                    <label>Technical Reasoning</label>
                    <p id="technical-reasoning"></p>
                </div>
                <div class="output-field">
                    <label>Architecture References</label>
                    <p id="architecture-references"></p>
                </div>
                <div class="output-field">
                    <label>Best Practice Links</label>
                    <p id="best-practice-links"></p>
                </div>
                <div class="output-field">
                    <label>Limitations and Risks</label>
                    <p id="limitations-risks"></p>
                </div>
                <div class="output-field">
                    <label>Operational Guidance</label>
                    <p id="operational-guidance"></p>
                </div>
                <div class="output-field">
                    <label>Leadership Summary</label>
                    <p id="leadership-summary"></p>
                </div>
            </div>
            <button id="generate-diagram-btn" style="margin-top: 1em; padding: 10px; display: none;">Generate Architecture Diagram</button>
        </div>
        <div class="output-section" id="diagram-section" style="display: none;">
            <h2>Generated Architecture</h2>
            <div id="diagram-container" style="width: 100%; height: 500px; border: 1px solid #ccc;"></div>
        </div>
    </div>
    <script src="https://viewer.diagrams.net/js/viewer-static.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const errorBanner = document.getElementById('error-banner');
            const RTO_RPO_BAND_MAP = {
                'Band A': '< 15 mins',
                'Band B': '15-60 mins',
                'Band C': '1-4 hours',
                'Band D': '4-12 hours',
                'Band E': '12-24 hours',
                'Band F': '> 24 hours'
            };
            const BASELINE_SERVICE_OPTIONS = Array.from(document.querySelectorAll('#azure-service option'))
                .map(option => option.value)
                .filter(Boolean);
            const BASELINE_CRITICALITY_OPTIONS = Array.from(document.querySelectorAll('#criticality option'))
                .map(option => option.value)
                .filter(Boolean);

            function showErrorBanner(msg) {
                errorBanner.innerHTML = msg;
                errorBanner.style.display = 'block';
            }
            function hideErrorBanner() {
                errorBanner.style.display = 'none';
            }
            const themeToggle = document.getElementById('theme-toggle');
            function setTheme(dark) {
                if (dark) {
                    document.body.classList.add('dark-theme');
                    themeToggle.textContent = '☀️ Light';
                } else {
                    document.body.classList.remove('dark-theme');
                    themeToggle.textContent = '🌙 Dark';
                }
                localStorage.setItem('theme', dark ? 'dark' : 'light');
            }
            (function() {
                const saved = localStorage.getItem('theme');
                setTheme(saved === 'dark');
            })();
            themeToggle.addEventListener('click', function() {
                const isDark = document.body.classList.contains('dark-theme');
                setTheme(!isDark);
            });
            let currentRecommendation = null;
            const btnGenerateDiagram = document.getElementById('generate-diagram-btn');
            const diagramSection = document.getElementById('diagram-section');
            const diagramContainer = document.getElementById('diagram-container');

            const inputs = {
                service: document.getElementById('azure-service'),
                workload: document.getElementById('workload-category'),
                criticality: document.getElementById('criticality'),
                rto: document.getElementById('rto'),
                rpo: document.getElementById('rpo'),
                region: document.getElementById('region-preference'),
                topology: document.getElementById('topology-preference'),
                cost: document.getElementById('cost-sensitivity'),
                simplicity: document.getElementById('simplicity-resilience')
            };

            const outputs = {
                decisionPosture: document.getElementById('decision-posture'),
                recommendationBasis: document.getElementById('recommendation-basis'),
                validationRequirement: document.getElementById('validation-requirement'),
                validationGuardrails: document.getElementById('validation-guardrails'),
                haApproach: document.getElementById('ha-approach'),
                drApproach: document.getElementById('dr-approach'),
                architecturePattern: document.getElementById('architecture-pattern'),
                resiliencyClassification: document.getElementById('resiliency-classification'),
                technicalReasoning: document.getElementById('technical-reasoning'),
                architectureReferences: document.getElementById('architecture-references'),
                bestPracticeLinks: document.getElementById('best-practice-links'),
                limitationsRisks: document.getElementById('limitations-risks'),
                operationalGuidance: document.getElementById('operational-guidance'),
                leadershipSummary: document.getElementById('leadership-summary')
            };

            const scorecards = {
                cost: document.getElementById('scorecard-cost'),
                costNote: document.getElementById('scorecard-cost-note'),
                complexity: document.getElementById('scorecard-complexity'),
                complexityNote: document.getElementById('scorecard-complexity-note'),
                resiliency: document.getElementById('scorecard-resiliency'),
                resiliencyNote: document.getElementById('scorecard-resiliency-note'),
                confidence: document.getElementById('scorecard-confidence'),
                confidenceNote: document.getElementById('scorecard-confidence-note')
            };

            const catalogContext = {
                itemType: document.getElementById('catalog-item-type'),
                serviceCategory: document.getElementById('catalog-service-category'),
                coverage: document.getElementById('catalog-coverage-status'),
                notes: document.getElementById('catalog-context-notes')
            };

            let decisionMatrix = [];
            let serviceCatalog = [];
            let catalogModel = { serviceItems: [], workloadItems: [], businessInputs: [] };

            function cleanValue(value) {
                return String(value || '').replace(/\s+/g, ' ').trim();
            }

            function slugify(value) {
                return cleanValue(value)
                    .toLowerCase()
                    .replace(/[^a-z0-9]+/g, '-')
                    .replace(/^-|-$/g, '');
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function normalizeCriticality(value) {
                const cleaned = cleanValue(value);
                if (!cleaned) return '';
                const lowered = cleaned.toLowerCase();
                if (lowered === 'critical') return 'Critical';
                if (lowered === 'important') return 'Important';
                if (lowered === 'standard') return 'Standard';
                if (lowered === 'paas') return 'PaaS';
                return cleaned;
            }

            function canonicalizeServiceName(value) {
                const cleaned = cleanValue(value);
                if (!cleaned) return '';

                const aliases = {
                    security: 'Security',
                    'application gateway': 'Azure Application Gateway',
                    'azure application gateway': 'Azure Application Gateway',
                    'load balancer': 'Azure Load Balancer',
                    'azure load balancer': 'Azure Load Balancer',
                    'azure dns / private dns / dns resolver': 'Azure DNS / Private DNS / DNS Resolver'
                };

                return aliases[cleaned.toLowerCase()] || cleaned;
            }

            function classifyCatalogItem(displayName, metadata = {}) {
                const normalized = canonicalizeServiceName(displayName);
                const category = cleanValue(metadata['Service Category']);

                if (normalized === 'Security') {
                    return {
                        itemType: 'legacy_option',
                        notes: 'Legacy umbrella option preserved from the live app. It is not a single Azure service and should be refined to a concrete dependency or workload before sign-off.'
                    };
                }

                if (
                    /dependencies/i.test(normalized) ||
                    normalized === 'Azure Site-to-Site VPN' ||
                    normalized === 'Dynamics 365 (D365)' ||
                    normalized === 'Microsoft Fabric' ||
                    /Dependencies/i.test(category)
                ) {
                    return {
                        itemType: 'dependency_context',
                        notes: 'This selection represents a dependency or platform context. Recommendations should be validated against the surrounding workload and downstream failure domains.'
                    };
                }

                return {
                    itemType: 'azure_service',
                    notes: 'This selection maps to a named Azure service with service-aware decision support where source coverage exists.'
                };
            }

            function parseCsvLine(line) {
                const values = [];
                let current = '';
                let inQuotes = false;

                for (let index = 0; index < line.length; index += 1) {
                    const character = line[index];
                    const nextCharacter = line[index + 1];

                    if (character === '"') {
                        if (inQuotes && nextCharacter === '"') {
                            current += '"';
                            index += 1;
                        } else {
                            inQuotes = !inQuotes;
                        }
                    } else if (character === ',' && !inQuotes) {
                        values.push(current.trim());
                        current = '';
                    } else {
                        current += character;
                    }
                }

                values.push(current.trim());
                return values;
            }

            function parseCSV(text) {
                const lines = text
                    .split(/\r?\n/)
                    .map(line => line.trimEnd())
                    .filter(line => line.length > 0);

                if (lines.length === 0) {
                    return [];
                }

                const headers = parseCsvLine(lines[0]);

                return lines.slice(1).map(line => {
                    const values = parseCsvLine(line);
                    const row = {};

                    headers.forEach((header, index) => {
                        row[header] = values[index] || '';
                    });

                    return row;
                });
            }

            function getUniqueValues(rows, key) {
                return [...new Set(rows.map(row => cleanValue(row[key])).filter(Boolean))].sort((left, right) => left.localeCompare(right));
            }

            function buildSelectOption(value, label = value, meta = '') {
                return { value, label, meta };
            }

            function setSelectOptions(selectElement, options, selectedValue = '') {
                const placeholder = '<option value="">--Please choose an option--</option>';
                const normalizedOptions = options
                    .map(option => typeof option === 'string' ? buildSelectOption(option) : option)
                    .filter(option => cleanValue(option.value));

                const renderedOptions = normalizedOptions.map(option => {
                    const label = option.meta ? `${option.label} ${option.meta}` : option.label;
                    return `<option value="${escapeHtml(option.value)}">${escapeHtml(label)}</option>`;
                }).join('');

                selectElement.innerHTML = `${placeholder}${renderedOptions}`;

                if (selectedValue && normalizedOptions.some(option => option.value === selectedValue)) {
                    selectElement.value = selectedValue;
                } else if (normalizedOptions.length === 1) {
                    selectElement.value = normalizedOptions[0].value;
                }
            }

            function normalizeDecisionMatrix(rows) {
                return rows.map(row => ({
                    ...row,
                    'Azure Service': canonicalizeServiceName(row['Azure Service']),
                    'Workload Category': cleanValue(row['Workload Category']),
                    'Criticality': normalizeCriticality(row['Criticality']),
                    RTO: RTO_RPO_BAND_MAP[cleanValue(row['RTO Band'])] || cleanValue(row['RTO']) || '',
                    RPO: RTO_RPO_BAND_MAP[cleanValue(row['RPO Band'])] || cleanValue(row['RPO']) || '',
                    'Region Preference': cleanValue(row['Region Preference']),
                    'Topology Preference': cleanValue(row['Topology Preference']),
                    'Cost Sensitivity': cleanValue(row['Cost Sensitivity']),
                    'Simplicity vs Resilience': cleanValue(row['Simplicity vs Resilience']),
                    'Decision Confidence': cleanValue(row['Decision Confidence']),
                    'Date Reviewed': cleanValue(row['Date Reviewed'])
                }));
            }

            function normalizeServiceCatalog(rows) {
                return rows.map(row => ({
                    ...row,
                    'Azure Service': canonicalizeServiceName(row['Azure Service']),
                    'Service Category': cleanValue(row['Service Category']),
                    'Workload Category': cleanValue(row['Workload Category']),
                    Status: cleanValue(row.Status)
                }));
            }

            function buildCatalogModel() {
                const serviceMap = new Map();
                const workloadSet = new Set();

                function ensureServiceItem(rawDisplayName, metadata = {}, source = 'live') {
                    const displayName = canonicalizeServiceName(rawDisplayName);
                    if (!displayName) return;

                    const current = serviceMap.get(displayName);
                    const classification = classifyCatalogItem(displayName, metadata);
                    const directCoverage = decisionMatrix.some(row => row['Azure Service'] === displayName);
                    const status = cleanValue(metadata.Status);
                    const coverageStatus = directCoverage
                        ? 'Direct matrix coverage'
                        : status
                            ? `${status} catalog coverage`
                            : 'Catalog preserved, limited direct recommendation coverage';

                    const nextItem = current || {
                        id: slugify(displayName),
                        displayName,
                        normalizedName: displayName,
                        itemType: classification.itemType,
                        isVisible: true,
                        isSelectable: true,
                        legacyLabel: cleanValue(rawDisplayName) !== displayName ? cleanValue(rawDisplayName) : '',
                        notes: classification.notes,
                        serviceCategory: cleanValue(metadata['Service Category']) || 'Unclassified',
                        workloadCategories: new Set(),
                        criticalityOptions: new Set(BASELINE_CRITICALITY_OPTIONS),
                        metadata: {},
                        directCoverage,
                        coverageStatus,
                        source
                    };

                    nextItem.itemType = nextItem.itemType || classification.itemType;
                    nextItem.notes = nextItem.notes || classification.notes;
                    nextItem.serviceCategory = nextItem.serviceCategory === 'Unclassified' && cleanValue(metadata['Service Category'])
                        ? cleanValue(metadata['Service Category'])
                        : nextItem.serviceCategory;
                    nextItem.directCoverage = nextItem.directCoverage || directCoverage;
                    nextItem.coverageStatus = nextItem.directCoverage ? 'Direct matrix coverage' : coverageStatus;

                    if (cleanValue(metadata['Workload Category'])) {
                        nextItem.workloadCategories.add(cleanValue(metadata['Workload Category']));
                        workloadSet.add(cleanValue(metadata['Workload Category']));
                    }

                    cleanValue(metadata['Criticality Options']).split('|')
                        .map(normalizeCriticality)
                        .filter(Boolean)
                        .forEach(option => nextItem.criticalityOptions.add(option));

                    nextItem.metadata = { ...nextItem.metadata, ...metadata };
                    serviceMap.set(displayName, nextItem);
                }

                BASELINE_SERVICE_OPTIONS.forEach(service => ensureServiceItem(service, {}, 'live'));
                serviceCatalog.forEach(row => ensureServiceItem(row['Azure Service'], row, 'service_catalog'));

                decisionMatrix.forEach(row => {
                    ensureServiceItem(row['Azure Service'], { 'Workload Category': row['Workload Category'] }, 'decision_matrix');
                    const item = serviceMap.get(row['Azure Service']);
                    item.workloadCategories.add(row['Workload Category']);
                    item.criticalityOptions.add(normalizeCriticality(row['Criticality']));
                    workloadSet.add(row['Workload Category']);
                });

                const serviceItems = [...serviceMap.values()]
                    .map(item => ({
                        ...item,
                        workloadCategories: [...item.workloadCategories].sort((left, right) => left.localeCompare(right)),
                        criticalityOptions: [...item.criticalityOptions].sort((left, right) => left.localeCompare(right))
                    }))
                    .sort((left, right) => left.displayName.localeCompare(right.displayName));

                const workloadItems = [...workloadSet]
                    .map(workload => ({
                        id: slugify(workload),
                        displayName: workload,
                        normalizedName: workload,
                        itemType: 'workload_category',
                        isVisible: true,
                        isSelectable: true
                    }))
                    .sort((left, right) => left.displayName.localeCompare(right.displayName));

                const businessInputs = [
                    'Criticality',
                    'Desired RTO',
                    'Desired RPO',
                    'Region / Zone Preference',
                    'Topology Preference',
                    'Cost Sensitivity',
                    'Simplicity vs Resilience'
                ].map(value => ({
                    id: slugify(value),
                    displayName: value,
                    normalizedName: value,
                    itemType: 'business_input',
                    isVisible: true,
                    isSelectable: true
                }));

                return { serviceItems, workloadItems, businessInputs };
            }

            function getCatalogItem(serviceName) {
                const normalized = canonicalizeServiceName(serviceName);
                return catalogModel.serviceItems.find(item => item.displayName === normalized) || null;
            }

            function loadCatalogContext(selectedItem) {
                if (!selectedItem) {
                    catalogContext.itemType.textContent = 'Catalog type pending';
                    catalogContext.serviceCategory.textContent = 'Service category pending';
                    catalogContext.coverage.textContent = 'Coverage pending';
                    catalogContext.notes.textContent = 'Pick a service or platform context to see how the dashboard classifies it and how much direct recommendation coverage is available.';
                    return;
                }

                const prettyType = {
                    azure_service: 'Azure service',
                    dependency_context: 'Dependency context',
                    legacy_option: 'Legacy option'
                }[selectedItem.itemType] || 'Catalog item';

                catalogContext.itemType.textContent = prettyType;
                catalogContext.serviceCategory.textContent = selectedItem.serviceCategory || 'Unclassified';
                catalogContext.coverage.textContent = selectedItem.coverageStatus;
                catalogContext.notes.textContent = selectedItem.notes || 'Catalog context is available, but service-specific validation is still required.';
            }

            async function loadData() {
                try {
                    const [decisionResponse, catalogResponse] = await Promise.all([
                        fetch('data/rto_rpo_decision_matrix_expanded_cleaned.csv'),
                        fetch('data/service_catalog_template.csv')
                    ]);
                    if (!decisionResponse.ok) throw new Error('Failed to fetch decision matrix');

                    const csvText = await decisionResponse.text();
                    decisionMatrix = normalizeDecisionMatrix(parseCSV(csvText));

                    if (catalogResponse.ok) {
                        const catalogText = await catalogResponse.text();
                        serviceCatalog = normalizeServiceCatalog(parseCSV(catalogText));
                    }

                    catalogModel = buildCatalogModel();
                    initializeInputOptions();
                } catch (err) {
                    showErrorBanner('Could not load the decision support data. Please ensure the `data` folder is present and the file path is correct. <a href="https://learn.microsoft.com/azure/architecture/framework/resiliency/overview" target="_blank" style="color:#0078D4;">Learn more</a>. Error: ' + escapeHtml(err.message));
                }
            }

            function initializeInputOptions() {
                const selectedService = canonicalizeServiceName(inputs.service.value);
                const selectedWorkload = cleanValue(inputs.workload.value);
                const selectedCriticality = normalizeCriticality(inputs.criticality.value);

                const serviceOptions = catalogModel.serviceItems.map(item => {
                    const meta = item.itemType === 'legacy_option'
                        ? '(legacy)'
                        : item.itemType === 'dependency_context'
                            ? '(dependency)'
                            : '';
                    return buildSelectOption(item.displayName, item.displayName, meta);
                });

                setSelectOptions(inputs.service, serviceOptions, selectedService);
                refreshDependentOptions(selectedWorkload, selectedCriticality);
                loadCatalogContext(getCatalogItem(inputs.service.value));
            }

            function refreshDependentOptions(selectedWorkload = '', selectedCriticality = '') {
                const selectedService = canonicalizeServiceName(inputs.service.value);
                const selectedItem = getCatalogItem(selectedService);
                const allServiceRows = selectedService
                    ? decisionMatrix.filter(row => row['Azure Service'] === selectedService)
                    : decisionMatrix;
                const workloadCandidates = new Set(
                    selectedItem?.workloadCategories?.length
                        ? selectedItem.workloadCategories
                        : catalogModel.workloadItems.map(item => item.displayName)
                );
                allServiceRows.forEach(row => workloadCandidates.add(row['Workload Category']));

                const workloadOptions = [...workloadCandidates]
                    .filter(Boolean)
                    .sort((left, right) => left.localeCompare(right))
                    .map(value => buildSelectOption(value));
                setSelectOptions(inputs.workload, workloadOptions, selectedWorkload);

                const criticalityCandidates = new Set(selectedItem?.criticalityOptions || BASELINE_CRITICALITY_OPTIONS);
                allServiceRows
                    .filter(row => !inputs.workload.value || row['Workload Category'] === inputs.workload.value)
                    .forEach(row => criticalityCandidates.add(normalizeCriticality(row['Criticality'])));

                const criticalityOptions = [...criticalityCandidates]
                    .filter(Boolean)
                    .sort((left, right) => left.localeCompare(right))
                    .map(value => {
                        const label = value === 'Critical'
                            ? 'Critical (mission-critical business impact)'
                            : value === 'Important'
                                ? 'Important (material business impact)'
                                : value === 'Standard'
                                    ? 'Standard (tolerable disruption)'
                                    : value === 'PaaS'
                                        ? 'PaaS (legacy option)'
                                        : value;
                        return buildSelectOption(value, label);
                    });

                setSelectOptions(inputs.criticality, criticalityOptions, selectedCriticality);
                loadCatalogContext(selectedItem);
            }

            function getSelections() {
                return {
                    service: canonicalizeServiceName(inputs.service.value),
                    workload: cleanValue(inputs.workload.value),
                    criticality: normalizeCriticality(inputs.criticality.value),
                    rto: cleanValue(inputs.rto.value),
                    rpo: cleanValue(inputs.rpo.value),
                    region: cleanValue(inputs.region.value),
                    topology: cleanValue(inputs.topology.value),
                    cost: cleanValue(inputs.cost.value),
                    simplicity: cleanValue(inputs.simplicity.value)
                };
            }

            function rankConfidence(value) {
                const lowered = cleanValue(value).toLowerCase();
                if (lowered.includes('high')) return 3;
                if (lowered.includes('medium')) return 2;
                if (lowered.includes('low')) return 1;
                return 0;
            }

            function adjustConfidence(baseConfidence, matchType) {
                const ordered = ['Low', 'Medium', 'High'];
                const index = Math.max(0, ordered.indexOf(baseConfidence || 'Low'));
                if (matchType === 'direct') return ordered[index];
                if (matchType === 'service_fallback') return ordered[Math.max(0, index - 1)];
                return 'Low';
            }

            function scoreRow(row, selections) {
                let score = 0;
                const notes = [];

                if (selections.workload && row['Workload Category'] === selections.workload) {
                    score += 18;
                    notes.push('workload aligned');
                } else if (selections.workload) {
                    score -= 6;
                }

                if (selections.criticality && row['Criticality'] === selections.criticality) {
                    score += 14;
                    notes.push('criticality aligned');
                } else if (selections.criticality) {
                    score -= 8;
                }

                if (selections.rto && row.RTO === selections.rto) {
                    score += 12;
                    notes.push('RTO aligned');
                } else if (selections.rto) {
                    score -= 5;
                }

                if (selections.rpo && row.RPO === selections.rpo) {
                    score += 12;
                    notes.push('RPO aligned');
                } else if (selections.rpo) {
                    score -= 5;
                }

                if (selections.region && row['Region Preference'] === selections.region) {
                    score += 10;
                    notes.push('region preference aligned');
                } else if (selections.region) {
                    score -= 3;
                }

                if (selections.topology && row['Topology Preference'] === selections.topology) {
                    score += 10;
                    notes.push('topology aligned');
                } else if (selections.topology) {
                    score -= 3;
                }

                if (selections.cost && row['Cost Sensitivity'] === selections.cost) {
                    score += 8;
                    notes.push('cost posture aligned');
                }

                if (selections.simplicity && row['Simplicity vs Resilience'] === selections.simplicity) {
                    score += 8;
                    notes.push('delivery preference aligned');
                }

                score += rankConfidence(row['Decision Confidence']);
                return { row, score, notes };
            }

            function buildAdvisoryOnlyRecommendation(selectedItem, selections) {
                const workload = selections.workload || selectedItem?.workloadCategories?.[0] || 'selected workload';
                const posture = selectedItem?.itemType === 'dependency_context'
                    ? 'Dependency-aware advisory'
                    : 'Catalog-preserved advisory';
                const coverage = selectedItem?.coverageStatus || 'Catalog preserved, limited direct recommendation coverage';
                const notes = selectedItem?.notes || 'This item is visible in the live catalog, but its decision rules need workload-specific validation.';
                const metadata = selectedItem?.metadata || {};

                return {
                    'Azure Service': selections.service,
                    'Criticality': selections.criticality,
                    'Recommended HA Strategy': 'Validate in-region resiliency using the service-specific reliability guidance and confirm dependency behavior before implementation.',
                    'Recommended DR Strategy': 'Design regional continuity as a workload-specific pattern rather than assuming native DR coverage for this selector.',
                    'Recommended Architecture Pattern': 'Dependency-aware continuity review required',
                    'Delivers Local Resiliency': 'Service-specific',
                    'Delivers Zonal Resiliency': 'Service-specific',
                    'Delivers Regional Resiliency': 'Partial',
                    'Why This Fits': `The selected item is preserved in the live catalog as ${selectedItem?.itemType === 'legacy_option' ? 'a legacy umbrella option' : 'a dependency-aware context'}. Use ${workload} continuity requirements, downstream dependencies, and region support to convert this into a validated target architecture.`,
                    'Key Caveats': notes,
                    'Operational Prerequisites': cleanValue(metadata['Typical Pattern Notes']) || 'Confirm supporting dependencies, region support, failover ownership, and runbooks before implementation.',
                    'Primary Diagram Link': '',
                    'Primary Documentation Link': '',
                    'Cost Level': 'Not rated',
                    'Complexity Level': 'High',
                    'Decision Confidence': 'Low',
                    'Date Reviewed': cleanValue(metadata['Status']) || 'Catalog only',
                    '__catalogItem': selectedItem,
                    '__matchType': 'catalog_only',
                    '__decisionPosture': posture,
                    '__recommendationBasis': `${coverage}. No direct service-level matrix row was found for this exact selector, so the output is intentionally advisory.`,
                    '__validationRequirement': 'High-touch human validation required',
                    '__validationGuardrails': `${notes} Validate service behavior by region, supporting dependencies, and documented failover ownership before sign-off.`,
                    '__confidenceNote': 'Low confidence because the selection is catalog-preserved without a direct decision-matrix recommendation.',
                    '__canGenerateDiagram': false
                };
            }

            function findRecommendation() {
                if (decisionMatrix.length === 0) {
                    return;
                }

                const selections = getSelections();
                const selectedItem = getCatalogItem(selections.service);
                loadCatalogContext(selectedItem);

                if (!selections.service) {
                    updateDashboard(null);
                    return;
                }

                const serviceRows = decisionMatrix.filter(row => row['Azure Service'] === selections.service);
                if (serviceRows.length === 0) {
                    updateDashboard(buildAdvisoryOnlyRecommendation(selectedItem, selections));
                    return;
                }

                const exactMatches = serviceRows.filter(row =>
                    (!selections.workload || row['Workload Category'] === selections.workload) &&
                    (!selections.criticality || row['Criticality'] === selections.criticality) &&
                    (!selections.rto || row.RTO === selections.rto) &&
                    (!selections.rpo || row.RPO === selections.rpo) &&
                    (!selections.region || row['Region Preference'] === selections.region) &&
                    (!selections.topology || row['Topology Preference'] === selections.topology) &&
                    (!selections.cost || row['Cost Sensitivity'] === selections.cost) &&
                    (!selections.simplicity || row['Simplicity vs Resilience'] === selections.simplicity)
                );

                let recommendation;
                if (exactMatches.length > 0) {
                    const directMatch = exactMatches.sort((left, right) => rankConfidence(right['Decision Confidence']) - rankConfidence(left['Decision Confidence']))[0];
                    recommendation = {
                        ...directMatch,
                        '__catalogItem': selectedItem,
                        '__matchType': 'direct',
                        '__decisionPosture': 'Direct service-aware advisory',
                        '__recommendationBasis': 'Exact same-service match against the current decision matrix and the selected business inputs.',
                        '__validationRequirement': 'Service-specific review still required',
                        '__validationGuardrails': `Validate SKU, regional support, and dependent services for ${selections.service} before implementation. Native service guidance remains authoritative when it conflicts with this dashboard.`,
                        '__confidenceNote': `Direct matrix match reviewed on ${directMatch['Date Reviewed'] || 'an unknown date'}. Confidence still depends on region, SKU, and dependency validation.`,
                        '__canGenerateDiagram': true
                    };
                } else {
                    const ranked = serviceRows
                        .map(row => scoreRow(row, selections))
                        .sort((left, right) => right.score - left.score || rankConfidence(right.row['Decision Confidence']) - rankConfidence(left.row['Decision Confidence']));
                    const best = ranked[0];
                    recommendation = {
                        ...best.row,
                        'Decision Confidence': adjustConfidence(best.row['Decision Confidence'], 'service_fallback'),
                        '__catalogItem': selectedItem,
                        '__matchType': 'service_fallback',
                        '__decisionPosture': 'Same-service fallback advisory',
                        '__recommendationBasis': `No exact row matched every selected input, so the dashboard chose the closest same-service pattern based on ${best.notes.join(', ') || 'overall service fit'}.`,
                        '__validationRequirement': 'Human validation strongly recommended',
                        '__validationGuardrails': `Review the mismatched inputs for ${selections.service}, especially RTO/RPO, topology, and regional assumptions. This is a same-service fallback, not a guaranteed best fit.`,
                        '__confidenceNote': `Confidence was reduced because the recommendation is the closest same-service match rather than a direct input-for-input match. Source reviewed on ${best.row['Date Reviewed'] || 'an unknown date'}.`,
                        '__canGenerateDiagram': true
                    };
                }

                updateDashboard(recommendation);
            }

            function updateDashboard(rec) {
                if (rec) {
                    outputs.decisionPosture.textContent = rec.__decisionPosture || 'Advisory recommendation';
                    outputs.recommendationBasis.textContent = rec.__recommendationBasis || 'Recommendation basis unavailable.';
                    outputs.validationRequirement.textContent = rec.__validationRequirement || 'Human review required.';
                    outputs.validationGuardrails.textContent = rec.__validationGuardrails || 'Validate service specifics before sign-off.';
                    outputs.haApproach.textContent = rec['Recommended HA Strategy'] || 'N/A';
                    outputs.drApproach.textContent = rec['Recommended DR Strategy'] || 'N/A';
                    outputs.architecturePattern.textContent = rec['Recommended Architecture Pattern'] || 'N/A';
                    outputs.resiliencyClassification.textContent = `HA coverage: Local ${rec['Delivers Local Resiliency'] || 'Unknown'} | Zonal ${rec['Delivers Zonal Resiliency'] || 'Unknown'} | DR coverage: Regional ${rec['Delivers Regional Resiliency'] || 'Unknown'}`;
                    outputs.technicalReasoning.textContent = rec['Why This Fits'] || 'N/A';
                    
                    const refLink = rec['Primary Diagram Link'];
                    if (refLink && refLink.startsWith('http')) {
                        outputs.architectureReferences.innerHTML = `<a href="${refLink}" target="_blank">${refLink}</a>`;
                    } else {
                        outputs.architectureReferences.textContent = refLink || 'N/A';
                    }

                    const bestPracticeLink = rec['Primary Documentation Link'];
                     if (bestPracticeLink && bestPracticeLink.startsWith('http')) {
                        outputs.bestPracticeLinks.innerHTML = `<a href="${bestPracticeLink}" target="_blank">${bestPracticeLink}</a>`;
                    } else {
                        outputs.bestPracticeLinks.textContent = bestPracticeLink || 'N/A';
                    }

                    outputs.limitationsRisks.textContent = rec['Key Caveats'] || 'N/A';
                    outputs.operationalGuidance.textContent = rec['Operational Prerequisites'] || 'N/A';
                    outputs.leadershipSummary.textContent = generateLeadershipSummary(rec);
                    updateScorecards(rec);
                    
                    currentRecommendation = rec;
                    btnGenerateDiagram.style.display = rec.__canGenerateDiagram && rec['Recommended Architecture Pattern'] && !rec['Recommended Architecture Pattern'].includes('continuity review required')
                        ? 'block'
                        : 'none';
                    diagramSection.style.display = 'none';

                } else {
                    Object.values(outputs).forEach(p => p.innerHTML = '');
                    outputs.decisionPosture.textContent = 'Awaiting selection';
                    outputs.recommendationBasis.textContent = 'Select inputs to evaluate direct matrix coverage and fallback behavior.';
                    outputs.validationRequirement.textContent = 'Human review remains required for final architecture approval.';
                    outputs.validationGuardrails.textContent = 'Guardrails will appear here when a recommendation needs service-specific verification, region validation, or dependency review.';
                    outputs.leadershipSummary.textContent = '';
                    resetScorecards();
                    currentRecommendation = null;
                    btnGenerateDiagram.style.display = 'none';
                    diagramSection.style.display = 'none';
                }
            }

            function levelToClass(level) {
                const normalized = (level || '').toLowerCase();
                if (normalized.includes('low')) return 'score-low';
                if (normalized.includes('medium')) return 'score-medium';
                if (normalized.includes('high')) return 'score-high';
                if (normalized.includes('partial')) return 'score-partial';
                if (normalized.includes('yes') || normalized.includes('strong')) return 'score-strong';
                if (normalized.includes('not rated') || normalized.includes('unknown')) return 'score-unknown';
                return 'score-mixed';
            }

            function setScorecardValue(element, value, note, noteElement) {
                element.textContent = value || 'Not rated';
                element.className = `scorecard-value ${levelToClass(value)}`;
                noteElement.textContent = note;
            }

            function getResiliencyProfile(rec) {
                const local = rec['Delivers Local Resiliency'] || 'No';
                const zonal = rec['Delivers Zonal Resiliency'] || 'No';
                const regional = rec['Delivers Regional Resiliency'] || 'No';
                const normalizedValues = [local, zonal, regional].map(value => String(value).toLowerCase());
                const yesCount = normalizedValues.filter(value => value === 'yes').length;
                const partialCount = normalizedValues.filter(value => value === 'partial' || value === 'service-specific' || value === 'n/a').length;

                let label = 'Targeted';
                if (yesCount === 3) {
                    label = 'Strong';
                } else if (yesCount >= 2 || partialCount > 0) {
                    label = 'Balanced';
                }

                const note = `Local: ${local} | Zonal: ${zonal} | Regional: ${regional}`;
                return { label, note };
            }

            function updateScorecards(rec) {
                const resiliency = getResiliencyProfile(rec);
                setScorecardValue(
                    scorecards.cost,
                    rec['Cost Level'],
                    `Estimated spend profile: ${rec['Cost Level'] || 'Not rated'}.`,
                    scorecards.costNote
                );
                setScorecardValue(
                    scorecards.complexity,
                    rec['Complexity Level'],
                    `Delivery and runbook burden: ${rec['Complexity Level'] || 'Not rated'}.`,
                    scorecards.complexityNote
                );
                setScorecardValue(
                    scorecards.resiliency,
                    resiliency.label,
                    resiliency.note,
                    scorecards.resiliencyNote
                );
                setScorecardValue(
                    scorecards.confidence,
                    rec['Decision Confidence'],
                    rec.__confidenceNote || `Confidence from matrix review date ${rec['Date Reviewed'] || 'unknown'}.`,
                    scorecards.confidenceNote
                );
            }

            function resetScorecards() {
                setScorecardValue(scorecards.cost, 'Not rated', 'Spend profile based on the current recommendation.', scorecards.costNote);
                setScorecardValue(scorecards.complexity, 'Not rated', 'Operational burden and implementation effort.', scorecards.complexityNote);
                setScorecardValue(scorecards.resiliency, 'Not rated', 'Coverage across local, zonal, and regional failure modes.', scorecards.resiliencyNote);
                setScorecardValue(scorecards.confidence, 'Not rated', 'Confidence level based on the decision matrix source.', scorecards.confidenceNote);
            }

            function generateLeadershipSummary(rec) {
                if (!rec) return 'No recommendation available for the selected criteria.';

                const service = rec['Azure Service'];
                const criticality = rec['Criticality'] ? rec['Criticality'].toLowerCase() : 'selected';
                const ha = rec['Recommended HA Strategy'];
                const dr = rec['Recommended DR Strategy'];
                const cost = rec['Cost Level'] || 'undefined';
                const complexity = rec['Complexity Level'] || 'undefined';

                return `Advisory summary: for the ${criticality} ${service} context, the dashboard points toward ${ha} for HA and ${dr} for DR. This indicates a ${complexity} delivery posture with a ${cost} cost profile, but final architecture approval still depends on service-specific validation, regional support, and dependency review.`;
            }

