                    return buildCosmosDiagram();
                } else if (pattern.includes("Global Front Door plus multi-region")) {
                    return buildFrontDoorDiagram();
                } else if (pattern.includes("Regional Application Gateway pair")) {
                    return buildAppGatewayDiagram();
                } else if (pattern.includes("Premium classic multi-region API gateways with AI-specific backend routing")) {
                    return buildApiManagementDiagram(true);
                } else if (pattern.includes("Premium classic multi-region API gateways")) {
